{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "ESP-IDF: version",
      "type": "shell",
      "command": "source /opt/esp/idf/export.sh >/dev/null && idf.py --version",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": false,
        "focus": false,
        "showReuseMessage": false
      }
    },
    {
      "label": "ESP-IDF: set target esp32s3",
      "type": "shell",
      "command": "source /opt/esp/idf/export.sh >/dev/null && idf.py set-target esp32s3",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": false,
        "focus": true,
        "showReuseMessage": false
      }
    },
    {
